# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Bitrix24
BITRIX24_WEBHOOK=https://your-domain.bitrix24.com.br/rest/1/your_webhook_code/

# SEFAZ
SEFAZ_AMBIENTE=homologacao
SEFAZ_CERTIFICADO_PATH=./certificado.pfx
SEFAZ_CERTIFICADO_PASSWORD=your_password

# Open Finance
OPEN_FINANCE_CLIENT_ID=your_client_id
OPEN_FINANCE_CLIENT_SECRET=your_client_secret
OPEN_FINANCE_REDIRECT_URI=https://yourdomain.com/callback

# Sentry
VITE_SENTRY_DSN=your_sentry_dsn
VITE_SENTRY_ENVIRONMENT=development

# Email
SENDGRID_API_KEY=your_sendgrid_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_password

# WhatsApp
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=5511999999999

# Environment
VITE_ENVIRONMENT=development
VITE_API_URL=http://localhost:54321
