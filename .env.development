# Development Environment
VITE_ENVIRONMENT=development

# Debug mode
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Features flags
VITE_ENABLE_EXPERT=true
VITE_ENABLE_OPEN_FINANCE=true
VITE_ENABLE_ANALYTICS=false

# Note: VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY 
# are automatically set by Lovable Cloud in .env
# Do NOT override them here!
